# Copy to .env and fill in. (.env is gitignored.)

# SQLite database file (relative to /prisma)
DATABASE_URL="file:./dev.db"

# Public origin (no trailing slash) — used for SEO / Open Graph / sitemap / canonical.
NEXT_PUBLIC_SITE_URL="https://core.uit.edu.vn"

# Serve the whole site under this path prefix (e.g. /core). Empty = root (default).
NEXT_PUBLIC_BASE_PATH=""

# Admin login password — CHANGE THIS
ADMIN_PASSWORD="change-me"

# Secret used to sign the admin session cookie — use a long random string
AUTH_SECRET="generate-a-long-random-string"
